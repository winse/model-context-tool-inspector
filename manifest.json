{
  "manifest_version": 3,
  "name": "WebMCP - Model Context Tool Inspector",
  "description": "Inspect, monitor, and execute WebMCP tools manually or with OpenAI / Anthropic LLMs",
  "version": "1.10.0",
  "minimum_chrome_version": "148.0.7778.56",
  "permissions": ["sidePanel", "activeTab", "scripting", "webNavigation", "storage"],
  "host_permissions": ["<all_urls>"],
  "update_url": "https://clients2.google.com/service/update2/crx",
  "action": {},
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "match_about_blank": true,
      "runAt": "document_start",
      "js": ["content.js"]
    }
  ]
}
